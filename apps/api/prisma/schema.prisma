generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  password        String
  role            String   @default("gestao") // admin, gestao, comercial, analitico
  allowedModules  String?  // JSON array of allowed module paths e.g. ["/dashboard","/crm"]
  isActive            Boolean  @default(true)
  mustChangePassword  Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
}

model Client {
  id               String   @id @default(cuid())
  companyName      String
  tradeName        String?
  cnpj             String?  @unique
  responsible      String
  phone            String?
  email            String?
  whatsapp         String?
  segment          String?
  address          String?
  addressNumber    String?
  neighborhood     String?
  city             String?
  state            String?
  zipCode          String?
  employeeCount    String?
  estimatedRevenue String?
  mainPains        String?
  strategicGoals   String?
  maturity         String?
  goonFitScore     Int?

  // CRM fields
  leadStage        String?   // NOVO, FOLLOW_UP, EM_NEGOCIACAO, FECHADO, PERDIDO
  leadSource       String?   // instagram, indicacao, evento, site, facebook, outro
  salesRep         String?   // nome do vendedor
  stageChangedAt   DateTime? // quando mudou de etapa (tracking de tempo)
  saleValue        Decimal?  @db.Decimal(10, 2)
  paymentMethod    String?   // BOLETO, PIX
  saleInstallments Int?
  installmentValue Decimal?  @db.Decimal(10, 2)
  leadNotes        String?   // observações / histórico de contatos
  closedAt         DateTime? // data de fechamento

  // AURA 360 modules (JSON array of selected module codes)
  selectedModules  String?  // JSON array: ["BRANDING","DIRECAO_CRIATIVA",...]
  suggestedProduct String?  // GE, GI, TTS, AURA — programa sugerido pelo comercial

  // Checklist flags
  hasContract      Boolean  @default(false)
  hasBilling       Boolean  @default(false)
  isClientActive   Boolean  @default(false)

  status           String   @default("ACTIVE")

  plans        ClientPlan[]
  contracts    Contract[]
  onboarding   Onboarding?
  activityLogs ActivityLog[]
  payments     Payment[]
  pendencies   Pendency[]
  commissions  Commission[]
  interactions LeadInteraction[]
  meetings     Meeting[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([leadStage])
  @@index([salesRep])
}

model Meeting {
  id          String    @id @default(cuid())
  clientId    String?
  title       String
  type        String    // INDIVIDUAL, GRUPO, DIAGNOSTICO, PLANO_VOO, KICKOFF, FOLLOW_UP, RG, COMERCIAL, ALINHAMENTO
  category    String    @default("MENTORIA") // MENTORIA, COMERCIAL, GESTAO, OUTRO
  date        DateTime
  duration    Int       @default(60) // minutes
  mentorName  String?
  notes       String?
  status      String    @default("SCHEDULED") // SCHEDULED, DONE, CANCELLED, NO_SHOW
  doneAt      DateTime?

  client      Client?   @relation(fields: [clientId], references: [id])

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([clientId])
  @@index([date])
  @@index([mentorName])
  @@index([status])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  stage       String    @default("TODO") // TODO, DOING, DONE
  priority    String    @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  assignee    String?   // responsible person
  dueDate     DateTime?
  tags        String?   // JSON array of tag names e.g. ["marketing","urgente"]
  order       Int       @default(0)
  completedAt DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([stage])
  @@index([assignee])
  @@index([dueDate])
}

model Product {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)

  plans ClientPlan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ClientPlan {
  id               String    @id @default(cuid())
  clientId         String
  productId        String
  value            Decimal   @db.Decimal(10, 2)
  paymentType      String
  installments     Int?
  installmentValue Decimal?  @db.Decimal(10, 2)
  cycleDuration    Int?
  cycleNumber      Int       @default(1)
  startDate        DateTime
  endDate          DateTime?
  status           String    @default("ACTIVE")
  notes            String?

  // Financial dates (can differ from contract dates)
  paymentStartDate  DateTime?
  paymentEndDate    DateTime?
  paymentDay        Int?      // day of month for installments (1-31)

  // Advance (adiantamento via app financeiro)
  wasAdvanced       Boolean   @default(false)
  advanceValue      Decimal?  @db.Decimal(10, 2) // valor recebido no adiantamento

  // Renewal tracking
  renewalStatus     String?   // null, PENDING, NOTIFIED, RENEWED, DECLINED

  client    Client     @relation(fields: [clientId], references: [id])
  product   Product    @relation(fields: [productId], references: [id])
  contracts Contract[]
  payments  Payment[]
  mentors   PlanMentor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([productId])
  @@index([status])
  @@index([endDate])
  @@index([clientId, status])
}

model PlanMentor {
  id          String    @id @default(cuid())
  planId      String
  mentorName  String
  value       Decimal   @db.Decimal(10, 2)
  notes       String?

  plan        ClientPlan @relation(fields: [planId], references: [id])

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([planId])
  @@index([mentorName])
}

model Contract {
  id              String    @id @default(cuid())
  clientId        String
  clientPlanId    String?
  templateType    String
  status          String    @default("DRAFT")
  version         Int       @default(1)
  dynamicFields   Json
  generatedPdfUrl String?
  sentAt          DateTime?
  signedAt        DateTime?
  isSigned        Boolean   @default(false)
  signatureDate   DateTime?

  client     Client      @relation(fields: [clientId], references: [id])
  clientPlan ClientPlan? @relation(fields: [clientPlanId], references: [id])
  payments   Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([clientPlanId])
  @@index([status])
  @@index([isSigned])
}

model Onboarding {
  id           String @id @default(cuid())
  clientId     String @unique
  currentStage String @default("CLIENT_CLOSED")
  notes        String?

  client Client @relation(fields: [clientId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id          String   @id @default(cuid())
  clientId    String?
  entityType  String
  entityId    String
  action      String
  fromValue   String?
  toValue     String?
  description String?
  userId      String?

  client Client? @relation(fields: [clientId], references: [id])

  createdAt DateTime @default(now())

  @@index([clientId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model Payment {
  id                String    @id @default(cuid())
  clientId          String
  clientPlanId      String?
  contractId        String?
  installment       Int       // parcela number (1, 2, 3...)
  totalInstallments Int       // total (6, 12...)
  dueDate           DateTime  // vencimento
  value             Decimal   @db.Decimal(10, 2)
  status            String    @default("PENDING") // PENDING, PAID, OVERDUE, CANCELLED, SCHEDULED
  paidAt            DateTime? // data do pagamento
  observation       String?

  client      Client      @relation(fields: [clientId], references: [id])
  clientPlan  ClientPlan? @relation(fields: [clientPlanId], references: [id])
  contract    Contract?   @relation(fields: [contractId], references: [id])
  commissions Commission[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clientId])
  @@index([clientPlanId])
  @@index([contractId])
  @@index([status])
  @@index([dueDate])
  @@index([status, dueDate])
}

model Pendency {
  id          String    @id @default(cuid())
  clientId    String
  type        String    // CONTRACT_UNSIGNED, PAYMENT_OVERDUE, PAYMENT_DUE_SOON, RENEWAL_PENDING, DOCUMENT_MISSING, CONTACT_NEEDED, OTHER
  status      String    @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED
  description String?
  relatedId   String?   // ID of related payment, contract, etc.
  resolvedAt  DateTime?

  client      Client    @relation(fields: [clientId], references: [id])

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([type])
  @@index([type, clientId, status])
}

model Commission {
  id            String    @id @default(cuid())
  clientId      String
  paymentId     String
  salesRep      String    // vendedor name
  percentage    Decimal   @db.Decimal(5, 2) // ex: 10.00 = 10%
  baseValue     Decimal   @db.Decimal(10, 2) // valor da parcela
  value         Decimal   @db.Decimal(10, 2) // valor da comissão calculado
  installment   Int       // parcela number
  totalInstallments Int   // total parcelas
  status        String    @default("PENDING") // PENDING, PAID, CANCELLED
  paidAt        DateTime?
  cancelledAt   DateTime?

  client        Client    @relation(fields: [clientId], references: [id])
  payment       Payment   @relation(fields: [paymentId], references: [id])

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([clientId])
  @@index([paymentId])
  @@index([salesRep])
  @@index([status])
  @@index([salesRep, status])
}

model Expense {
  id          String    @id @default(cuid())
  description String
  category    String    // SISTEMAS, MARKETING, PESSOAS, ESTRUTURA, OUTRO
  value       Decimal   @db.Decimal(10, 2)
  recurrence  String    @default("UNICA") // UNICA, MENSAL, TRIMESTRAL, ANUAL
  dueDate     DateTime
  status      String    @default("PREVISTO") // PREVISTO, PAGO
  paidAt      DateTime?
  notes       String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([category])
  @@index([status])
  @@index([dueDate])
  @@index([recurrence])
}

model LeadInteraction {
  id          String   @id @default(cuid())
  clientId    String
  type        String   // LIGACAO, WHATSAPP, EMAIL, REUNIAO, NOTA, PROPOSTA, FOLLOW_UP
  description String
  userId      String?  // quem registrou
  userName    String?  // nome de quem registrou
  scheduledAt DateTime? // agendamento de proximo contato

  client      Client   @relation(fields: [clientId], references: [id])

  createdAt   DateTime @default(now())

  @@index([clientId])
  @@index([clientId, createdAt])
  @@index([type])
}
