generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Client {
  id               String   @id @default(cuid())
  companyName      String
  tradeName        String?
  cnpj             String?  @unique
  responsible      String
  phone            String?
  email            String?
  whatsapp         String?
  segment          String?
  address          String?
  addressNumber    String?
  neighborhood     String?
  city             String?
  state            String?
  zipCode          String?
  employeeCount    String?
  estimatedRevenue String?
  mainPains        String?
  strategicGoals   String?
  maturity         String?
  goonFitScore     Int?
  status           String   @default("ACTIVE")

  plans        ClientPlan[]
  contracts    Contract[]
  onboarding   Onboarding?
  activityLogs ActivityLog[]
  payments     Payment[]
  pendencies   Pendency[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model Product {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)

  plans ClientPlan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ClientPlan {
  id               String    @id @default(cuid())
  clientId         String
  productId        String
  value            Decimal   @db.Decimal(10, 2)
  paymentType      String
  installments     Int?
  installmentValue Decimal?  @db.Decimal(10, 2)
  cycleDuration    Int?
  cycleNumber      Int       @default(1)
  startDate        DateTime
  endDate          DateTime?
  status           String    @default("ACTIVE")
  notes            String?

  // Financial dates (can differ from contract dates)
  paymentStartDate  DateTime?
  paymentEndDate    DateTime?
  paymentDay        Int?      // day of month for installments (1-31)

  // Renewal tracking
  renewalStatus     String?   // null, PENDING, NOTIFIED, RENEWED, DECLINED

  client    Client     @relation(fields: [clientId], references: [id])
  product   Product    @relation(fields: [productId], references: [id])
  contracts Contract[]
  payments  Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([productId])
  @@index([status])
  @@index([endDate])
  @@index([clientId, status])
}

model Contract {
  id              String    @id @default(cuid())
  clientId        String
  clientPlanId    String?
  templateType    String
  status          String    @default("DRAFT")
  version         Int       @default(1)
  dynamicFields   Json
  generatedPdfUrl String?
  sentAt          DateTime?
  signedAt        DateTime?
  isSigned        Boolean   @default(false)
  signatureDate   DateTime?

  client     Client      @relation(fields: [clientId], references: [id])
  clientPlan ClientPlan? @relation(fields: [clientPlanId], references: [id])
  payments   Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([clientPlanId])
  @@index([status])
  @@index([isSigned])
}

model Onboarding {
  id           String @id @default(cuid())
  clientId     String @unique
  currentStage String @default("CLIENT_CLOSED")
  notes        String?

  client Client @relation(fields: [clientId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id          String   @id @default(cuid())
  clientId    String?
  entityType  String
  entityId    String
  action      String
  fromValue   String?
  toValue     String?
  description String?
  userId      String?

  client Client? @relation(fields: [clientId], references: [id])

  createdAt DateTime @default(now())

  @@index([clientId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model Payment {
  id                String    @id @default(cuid())
  clientId          String
  clientPlanId      String?
  contractId        String?
  installment       Int       // parcela number (1, 2, 3...)
  totalInstallments Int       // total (6, 12...)
  dueDate           DateTime  // vencimento
  value             Decimal   @db.Decimal(10, 2)
  status            String    @default("PENDING") // PENDING, PAID, OVERDUE, CANCELLED, SCHEDULED
  paidAt            DateTime? // data do pagamento
  observation       String?

  client      Client      @relation(fields: [clientId], references: [id])
  clientPlan  ClientPlan? @relation(fields: [clientPlanId], references: [id])
  contract    Contract?   @relation(fields: [contractId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clientId])
  @@index([clientPlanId])
  @@index([contractId])
  @@index([status])
  @@index([dueDate])
  @@index([status, dueDate])
}

model Pendency {
  id          String    @id @default(cuid())
  clientId    String
  type        String    // CONTRACT_UNSIGNED, PAYMENT_OVERDUE, PAYMENT_DUE_SOON, RENEWAL_PENDING, DOCUMENT_MISSING, CONTACT_NEEDED, OTHER
  status      String    @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED
  description String?
  relatedId   String?   // ID of related payment, contract, etc.
  resolvedAt  DateTime?

  client      Client    @relation(fields: [clientId], references: [id])

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([type])
  @@index([type, clientId, status])
}
